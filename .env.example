# =============================================================================
# KAIS AIGC Platform V6.0 — Environment Variables
# =============================================================================
# 复制为 .env 并填写实际值: cp .env.example .env
# =============================================================================

# ----- 通用 -----
NODE_ENV=production
OUTPUT_DIR=/mnt/agents/output
MODELS_DIR=/opt/kais/models

# ----- 端口映射 -----
CORE_PORT=8000
MOVIE_AGENT_PORT=8001
GOLD_TEAM_PORT=8002
COMFYUI_PORT=8188
REVIEW_PORT=8090
POSTGRES_PORT=5432
REDIS_PORT=6379

# ----- PostgreSQL (audit-db) -----
POSTGRES_USER=kais
POSTGRES_PASSWORD=changeme_use_strong_password
POSTGRES_DB=kais_audit

# ----- Redis -----
# REDIS_URL=redis://redis:6379  (容器内自动设置)

# ----- Telegram Bot -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- 云端引擎 API Keys -----
KLING_API_KEY=
JIMENG_API_KEY=
JIMENG_SESSION=
SEEDANCE_API_KEY=
RUNWAY_API_KEY=
LUMA_API_KEY=

# ----- ComfyUI -----
COMFYUI_LISTEN=0.0.0.0
